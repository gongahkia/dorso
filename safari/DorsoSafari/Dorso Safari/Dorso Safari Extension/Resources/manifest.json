{
  "manifest_version": 3,
  "name": "Dorso",
  "version": "2.1.0",
  "description": "Protect selected AI chatbot sites until a matching LeetCode challenge is solved.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://www.perplexity.ai/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://www.deepseek.com/*",
    "https://copilot.microsoft.com/*",
    "https://socrat.ai/*",
    "https://huggingface.co/chat*",
    "https://writesonic.com/chat*",
    "https://you.com/*",
    "https://www.jasper.ai/*",
    "https://leetcode.com/problems/*"
  ],
  "icons": {
    "16": "extension/assets/icons/icon-16.png",
    "32": "extension/assets/icons/icon-32.png",
    "48": "extension/assets/icons/icon-48.png",
    "128": "extension/assets/icons/icon-128.png"
  },
  "action": {
    "default_popup": "extension/ui/popup.html",
    "default_icon": {
      "16": "extension/assets/icons/icon-16.png",
      "32": "extension/assets/icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://www.perplexity.ai/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://www.deepseek.com/*",
        "https://copilot.microsoft.com/*",
        "https://socrat.ai/*",
        "https://huggingface.co/chat*",
        "https://writesonic.com/chat*",
        "https://you.com/*",
        "https://www.jasper.ai/*"
      ],
      "js": [
        "extension/content/chatbot-gate.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": [
        "extension/content/leetcode.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "extension/background/index.js"
  }
}
