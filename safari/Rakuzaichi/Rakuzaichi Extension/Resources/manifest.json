{
  "manifest_version": 3,
  "name": "Rakuzaichi",
  "version": "2.0.0",
  "description": "Export LLM chat conversations in multiple formats",
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "128": "icon/128.png"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://chat.deepseek.com/*",
    "https://grok.com/*",
    "https://copilot.microsoft.com/*",
    "https://chat.mistral.ai/*",
    "https://huggingface.co/chat/*",
    "https://poe.com/*",
    "https://kimi.com/*",
    "https://chat.qwen.ai/*",
    "https://tongyi.aliyun.com/*",
    "https://chatglm.cn/*",
    "https://doubao.com/*",
    "https://www.doubao.com/*",
    "https://notebooklm.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon/16.png",
      "32": "icon/32.png",
      "48": "icon/48.png",
      "128": "icon/128.png"
    }
  },
  "background": {
    "scripts": [
      "compat.js",
      "logger.js",
      "converters.js",
      "filename.js",
      "storage.js",
      "history.js",
      "vendor/minisearch.js",
      "vault/db.js",
      "vault/dao.js",
      "vault/search-worker.js",
      "vault/search.js",
      "threads/scanner.js",
      "background-core.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://chat.deepseek.com/*",
        "https://grok.com/*",
        "https://copilot.microsoft.com/*",
        "https://chat.mistral.ai/*",
        "https://huggingface.co/chat/*",
        "https://poe.com/*",
        "https://kimi.com/*",
        "https://chat.qwen.ai/*",
        "https://tongyi.aliyun.com/*",
        "https://chatglm.cn/*",
        "https://doubao.com/*",
        "https://www.doubao.com/*",
        "https://notebooklm.google.com/*"
      ],
      "js": [
        "compat.js",
        "dom-utils.js",
        "schema.js",
        "logger.js",
        "platforms/chatgpt.js",
        "platforms/claude.js",
        "platforms/gemini.js",
        "platforms/perplexity.js",
        "platforms/deepseek.js",
        "platforms/grok.js",
        "platforms/copilot.js",
        "platforms/mistral.js",
        "platforms/huggingchat.js",
        "platforms/poe.js",
        "platforms/kimi.js",
        "platforms/qwen.js",
        "platforms/chatglm.js",
        "platforms/doubao.js",
        "platforms/notebooklm.js",
        "platforms/registry.js",
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html"
  },
  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "17.0"
    }
  }
}
