# Docker Compose Environment Variables

# Django
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database
DB_PASSWORD=secure_database_password_change_this

# Redis
REDIS_PASSWORD=secure_redis_password_change_this

# CORS (Browser Extension Origins)
CORS_ALLOWED_ORIGINS=chrome-extension://,moz-extension://

# Logging
LOG_LEVEL=INFO

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_password_change_this
