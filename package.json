{
  "name": "dorso",
  "version": "3.0.0-rc.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "node scripts/build-extension.mjs chrome",
    "build:firefox": "node scripts/build-extension.mjs firefox",
    "build:safari": "node scripts/build-extension.mjs safari",
    "sync:safari-wrapper": "node scripts/sync-safari-wrapper.mjs",
    "build:safari-app": "npm run build:safari && npm run sync:safari-wrapper",
    "test:unit": "node --test --test-concurrency=1 tests/unit/*.test.js",
    "test:shared": "npm test -- --runInBand --silent --passWithNoTests",
    "test:e2e": "npm test -- --reporter=line"
  }
}
