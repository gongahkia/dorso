{
  "name": "dorso",
  "version": "3.0.0-rc.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "node scripts/build-extension.mjs chrome",
    "build:firefox": "node scripts/build-extension.mjs firefox",
    "build:safari": "node scripts/build-extension.mjs safari",
    "build:userscript": "node scripts/build-userscript.mjs",
    "package:release": "npm run build && node scripts/package-extension-release.mjs",
    "sync:safari-wrapper": "node scripts/sync-safari-wrapper.mjs",
    "build:safari-app": "npm run build:safari && npm run sync:safari-wrapper",
    "build:dashboard-validator": "node scripts/build-dashboard-validator.mjs",
    "validate:packs": "node scripts/validate-packs.mjs",
    "test": "node --test src/shared/__tests__/*.test.js src/extension/lib/__tests__/*.test.js src/extension/ui/__tests__/*.test.js"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-cli": "^5.0.0",
    "esbuild": "^0.28.1",
    "web-ext": "^10.4.0"
  }
}
