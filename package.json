{
  "name": "rakuzaichi",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:chrome": "node scripts/build.mjs chrome",
    "build:firefox": "node scripts/build.mjs firefox",
    "build:safari": "node scripts/build.mjs safari",
    "check:permissions": "node scripts/check-permissions.mjs",
    "check:manifests": "node scripts/validate-manifests.mjs",
    "lint": "npm run build:firefox && npx web-ext lint --source-dir dist/firefox",
    "package": "npm run build && node scripts/package.mjs",
    "package:firefox": "npm run build:firefox && node scripts/package-firefox.mjs",
    "package:firefox-source": "node scripts/package-firefox-source.mjs",
    "safari:convert": "npm run build:safari && node scripts/convert-safari.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run build && npm test && npm run check:manifests && npm run check:permissions && npm run lint"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "minisearch": "7.2.0"
  }
}
