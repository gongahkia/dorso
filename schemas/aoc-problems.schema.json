{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dorso.dev/schemas/aoc-problems.schema.json",
  "title": "Dorso Advent of Code Metadata Pack",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "year",
      "day",
      "part",
      "url",
      "difficulty",
      "tags"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^aoc-[0-9]{4}-[0-9]{2}-part-[12]$"
      },
      "year": {
        "type": "integer",
        "minimum": 2015
      },
      "day": {
        "type": "integer",
        "minimum": 1,
        "maximum": 25
      },
      "part": {
        "type": "integer",
        "enum": [1, 2]
      },
      "url": {
        "type": "string",
        "pattern": "^https://adventofcode\\.com/[0-9]{4}/day/[0-9]{1,2}$"
      },
      "difficulty": {
        "type": "integer",
        "enum": [1, 2, 3, 4, 5]
      },
      "tags": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,40}$"
        },
        "uniqueItems": true
      }
    }
  }
}
