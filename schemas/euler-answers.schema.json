{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dorso.dev/schemas/euler-answers.schema.json",
  "title": "Dorso Project Euler Answer Hash Pack",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "url",
      "answerHash",
      "difficulty",
      "tags"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^pe-[0-9]{3,4}$"
      },
      "url": {
        "type": "string",
        "pattern": "^https://projecteuler\\.net/problem=[0-9]+$"
      },
      "answerHash": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "difficulty": {
        "type": "integer",
        "enum": [1, 2, 3, 4, 5]
      },
      "tags": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,40}$"
        },
        "uniqueItems": true
      }
    }
  }
}
