{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dorso.dev/schemas/mcq.schema.json",
  "title": "Dorso MCQ Pack",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "prompt",
      "choices",
      "answerIndex",
      "tags",
      "difficulty",
      "source"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
      },
      "prompt": {
        "type": "string",
        "minLength": 1
      },
      "choices": {
        "type": "array",
        "minItems": 2,
        "maxItems": 6,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "answerIndex": {
        "type": "integer",
        "minimum": 0,
        "maximum": 5
      },
      "tags": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,40}$"
        },
        "uniqueItems": true
      },
      "difficulty": {
        "type": "integer",
        "enum": [1, 2, 3, 4, 5]
      },
      "source": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]{1,60}$"
      }
    }
  }
}
