{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dorso.dev/schemas/drills.schema.json",
  "title": "Dorso Drill Pack",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "prompt",
      "expected",
      "language",
      "normalizers",
      "threshold",
      "tags",
      "difficulty"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
      },
      "prompt": {
        "type": "string",
        "minLength": 1
      },
      "expected": {
        "type": "string",
        "minLength": 1
      },
      "language": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]{1,40}$"
      },
      "normalizers": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["whitespace", "quotes", "semicolons", "casing"]
        },
        "uniqueItems": true
      },
      "threshold": {
        "type": "integer",
        "minimum": 0,
        "maximum": 20
      },
      "tags": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,40}$"
        },
        "uniqueItems": true
      },
      "difficulty": {
        "type": "integer",
        "enum": [1, 2, 3, 4, 5]
      }
    }
  }
}
