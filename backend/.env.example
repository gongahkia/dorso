# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for development, PostgreSQL for production)
# Leave commented for SQLite, uncomment for PostgreSQL
# DATABASE_URL=postgresql://dorso:password@localhost:5432/dorso

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# CORS (browser extension origins)
CORS_ALLOWED_ORIGINS=chrome-extension://,moz-extension://

# Logging
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# LeetCode API
LEETCODE_GRAPHQL_ENDPOINT=https://leetcode.com/graphql
